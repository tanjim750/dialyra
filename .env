# Flask
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY = your_flask_secret_key

# API versionyes
AUTHZ_V2_ENABLED=true
AUTHZ_V2_COMPARE_ENABLED = true

# Database
DB_HOST=dialyra-db
DB_PORT=5432
DB_NAME=dialyra_db
DB_USER=dialyra_user
DB_PASSWORD=dialyra_pass

# Optional full URL (if you use SQLAlchemy)
DATABASE_URL=postgresql://dialyra_user:dialyra_pass@dialyra-db:5432/dialyra_db

# Redis
REDIS_URL=redis://redis:6379

# First Superuser configuration
BOOTSTRAP_SUPERUSER_ENABLED=true
BOOTSTRAP_SUPERUSER_SECRET=tanjim123

# Audio assets storage
AUDIO_ASSETS_ROOT=/data/audio-assets
AUDIO_ASSET_EXTRA_CATEGORIES=queue_announcement,tts_prompt,agent_message
AUDIO_PLAYBACK_TEST_CHANNEL=Local/s@outbound
AUDIO_PLAYBACK_TEST_TIMEOUT_MS=10000
AUDIO_ASSET_MAX_FILE_SIZE_MB = 10
AUDIO_ASSET_ENFORCE_MIME = true
AUDIO_ASSET_ALLOWED_EXTENSIONS=wav,mp3

# TTS configauration
TTS_DEFAULT_PROVIDER = google
TTS_ENABLED_PROVIDERS = google,aws,azure
# google
GOOGLE_TTS_VARIANT=gtts #gemini-tts|gtts
GOOGLE_TTS_API_KEY=your_key
GOOGLE_GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GOOGLE_GEMINI_TTS_SAMPLE_RATE=24000
# openai
OPENAI_API_KEY = your_openai_api_key
OPENAI_TTS_ENDPOINT = https://api.openai.com/v1/audio/speech
OPENAI_TTS_MODEL = tts-1
OPENAI_TTS_VOICE = allison
# elevenlabs 
ELEVENLABS_API_KEY = your_elevenlabs_api_key
ELEVENLABS_TTS_BASE_URL = https://api.elevenlabs.io/v1
ELEVENLABS_TTS_VOICE_ID = 21m00Tcm4TlvDq8ikWAM
ELEVENLABS_TTS_MODEL_ID = standard
ELEVENLABS_TTS_OUTPUT_FORMAT = mp3

# AMI configuration
AMI_HOST=138.252.125.100
AMI_PORT=5038
AMI_USERNAME=admin
AMI_SECRET=dialyra123
AMI_EVENT_LISTENER_ENABLED=true
AMI_EVENT_RECONNECT_DELAY_SEC=2
SYSTEM_MAX_CONCURRENT_CALLS=100 # 0 means no limit
CALL_RETRY_MAX_ATTEMPTS=10

# FastAGI configuration
FASTAGI_INTERNAL_BASE_URL=http://dialyra-flask:5000
FASTAGI_INTERNAL_ACCESS_TOKEN=<access-token-with-flow:resolve,fastagi:runtime,events:write>
FASTAGI_INTERNAL_TIMEOUT_SEC=5
FASTAGI_MAX_RUNTIME_STEPS=32
FASTAGI_CALL_TOKEN_TTL_SEC=900

# login rate limit
LOGIN_MAX_FAILED_ATTEMPTS=10
LOGIN_RATE_LIMIT_WINDOW_MINUTES = 15

# pjsip configuration
PJSIP_CONFIG_PATH =/app/asterisk/pjsip.conf
PJSIP_TRANSPORT_NAME = transport-udp
SIP_REALTIME_ENABLED=true
SIP_REALTIME_DSN = postgresql://dialyra_user:dialyra_pass@dialyra-db:5432/dialyra_db
SIP_REALTIME_SCHEMA = public

# flow runtime canary rollout
FLOW_RUNTIME_CANARY_ENABLED=false
FLOW_RUNTIME_CANARY_PERCENT=100
FLOW_RUNTIME_CANARY_FORCE_BUSINESS_IDS=
FLOW_RUNTIME_CANARY_FORCE_FLOW_IDS=
FLOW_RUNTIME_ENABLED_NODE_TYPES=
FLOW_RUNTIME_ENABLE_PLAY_AUDIO=
FLOW_RUNTIME_ENABLE_SAY_TEXT=
FLOW_RUNTIME_ENABLE_TTS=
FLOW_RUNTIME_ENABLE_GATHER_INPUT=
FLOW_RUNTIME_ENABLE_CONDITION=
FLOW_RUNTIME_ENABLE_SET_VARIABLE=
FLOW_RUNTIME_ENABLE_GOTO=
FLOW_RUNTIME_ENABLE_WEBHOOK=
FLOW_RUNTIME_ENABLE_TRANSFER_CALL=
FLOW_RUNTIME_ENABLE_WAIT=
FLOW_RUNTIME_ENABLE_RECORD_CONTROL=
FLOW_RUNTIME_ENABLE_HANGUP=
