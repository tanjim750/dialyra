# Flask
FLASK_ENV=development
FLASK_DEBUG=1

# API versionyes
AUTHZ_V2_ENABLED=true
AUTHZ_V2_COMPARE_ENABLED = true

# Database
DB_HOST=dialyra-db
DB_PORT=5432
DB_NAME=dialyra_db
DB_USER=dialyra_user
DB_PASSWORD=dialyra_pass

# Optional full URL (if you use SQLAlchemy)
DATABASE_URL=postgresql://dialyra_user:dialyra_pass@dialyra-db:5432/dialyra_db

# Redis
REDIS_URL=redis://redis:6379

# AMI configuration
AMI_HOST=138.252.125.100
AMI_PORT=5038
AMI_USERNAME=admin
AMI_SECRET=dialyra123


BOOTSTRAP_SUPERUSER_ENABLED=true
BOOTSTRAP_SUPERUSER_SECRET=tanjim123

# login rate limit
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_MINUTES = 15

# pjsip configuration
PJSIP_CONFIG_PATH =/app/asterisk/pjsip.conf
PJSIP_TRANSPORT_NAME = transport-udp
SIP_REALTIME_ENABLED=true
SIP_REALTIME_DSN = postgresql://dialyra_user:dialyra_pass@dialyra-db:5432/dialyra_db
SIP_REALTIME_SCHEMA = public